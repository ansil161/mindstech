# Database configuration
DB_NAME=mindstech_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Django Security Settings
# Generate a secure random 50-character key for production
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# External Microservices
# Local Docker: http://ai-service:8000 | Local standalone: http://localhost:8001 | Render: https://mindstec-ai-service.onrender.com
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=secret-key
GOOGLE_TRANSLATE_API_KEY=
