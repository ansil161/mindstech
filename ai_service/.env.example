# ===========================================================================
# Mindstec AI Service — configuration
#
# Every value here has a working default in app/core/config.py; this file
# documents the ones you are most likely to change. Only AI_SERVICE_API_KEY,
# QDRANT_URL and at least one LLM key are genuinely required.
# ===========================================================================

# --- server ---------------------------------------------------------------
PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development          # 'production' switches logs to JSON
WEB_CONCURRENCY=2                # Gunicorn workers; size to CPU cores

# --- internal auth (REQUIRED) ---------------------------------------------
# Must match Django's AI_SERVICE_API_KEY. There is no fallback default: an
# unset value makes every request fail closed with 503.
AI_SERVICE_API_KEY=

# --- CORS -----------------------------------------------------------------
# Comma-separated origins. Leave empty to disable CORS entirely, which is the
# correct setting when this service is only ever reached via Django/Nginx.
BACKEND_CORS_ORIGINS=

# ===========================================================================
# LLM
# ===========================================================================
# LLM_PROVIDER picks the primary; the others form an automatic failover chain.
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional comma-separated lists to spread load across several keys per
# provider. Each single *_API_KEY above is automatically included.
OPENAI_API_KEYS=
GEMINI_API_KEYS=
GROQ_API_KEYS=

OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-flash-latest

LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=700
LLM_MAX_RETRIES=2

# TIMEOUT BUDGET — keep these coherent with the caller.
# Django's AIClient default timeout is 30s. A worst-case turn is
# classification + generation, so those two must fit inside it:
#   8 (classifier) + 20 (generation) = 28s < 30s Django < 120s Gunicorn
# Raising either without raising AI_SERVICE_TIMEOUT on the Django side means
# Django gives up while this service is still working — the user sees an error
# for a request that actually succeeded.
LLM_REQUEST_TIMEOUT_SECONDS=20
LLM_CLASSIFIER_TIMEOUT_SECONDS=8

# A key returning a quota/auth error is parked for this long before reuse.
API_KEY_COOLDOWN_SECONDS=60

# Circuit breaker: skip a provider entirely after this many consecutive
# failures instead of paying its timeout on every request while it is down.
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=30

# ===========================================================================
# Conversation engine
# ===========================================================================
# Master switch. Disabling routes every message straight to RAG (v1 behaviour)
# — an incident escape hatch, not a supported mode.
ENABLE_CONVERSATION_ENGINE=true

# Tier-2 LLM classification. Tier 1 (deterministic rules) always runs first and
# resolves most turns for free; this only covers ambiguous ones.
ENABLE_LLM_INTENT_CLASSIFICATION=true
CLASSIFIER_MAX_RETRIES=2

# Structured company FAQ answered without vector search.
ENABLE_FAQ_LAYER=true
FAQ_MIN_CONFIDENCE=0.62

# History
HISTORY_WINDOW_MESSAGES=6        # turns replayed into the prompt
HISTORY_MAX_MESSAGES=40          # retained per conversation (Redis LTRIM bound)
HISTORY_TTL_SECONDS=604800       # 7 days
HISTORY_MESSAGE_MAX_CHARS=1500
HISTORY_MEMORY_MAX_CONVERSATIONS=500

# ===========================================================================
# Embeddings
# ===========================================================================
EMBEDDING_PROVIDER=huggingface   # huggingface | sentence_transformer | openai
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_API_KEY=
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUEST_TIMEOUT_SECONDS=20
EMBEDDING_MAX_RETRIES=2
EMBEDDING_CACHE_MAX_SIZE=2048
EMBEDDING_CACHE_TTL_SECONDS=3600

# ===========================================================================
# Chunking (approximate tokens, via the chars/4 heuristic)
# ===========================================================================
CHUNK_SIZE=400
CHUNK_OVERLAP=50
INGEST_MAX_CONTENT_CHARS=2000000
INGEST_MAX_UPLOAD_BYTES=26214400

# ===========================================================================
# Retrieval
# ===========================================================================
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.30
RETRIEVAL_CONFIDENT_SCORE=0.55   # below this the model is told to hedge
RETRIEVAL_OVERFETCH_MULTIPLIER=3.0
RETRIEVAL_MAX_CONTEXT_CHUNKS=6
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=2
RETRIEVAL_DEDUP_SIMILARITY_THRESHOLD=0.90
RETRIEVAL_MAX_CONTEXT_TOKENS=3000

RETRIEVAL_ENABLE_RERANK=true
RERANK_LEXICAL_WEIGHT=0.3

# Hybrid: run a keyword branch alongside the vector branch and fuse the ranked
# lists. Recovers exact identifiers (part numbers, model codes) that dense
# embeddings routinely miss.
RETRIEVAL_ENABLE_HYBRID=true
RETRIEVAL_KEYWORD_LIMIT=10
RETRIEVAL_RRF_K=60

RETRIEVAL_ENABLE_MULTI_QUERY=true
RETRIEVAL_MAX_QUERY_VARIANTS=3

# When the first pass finds nothing, retry once at a lower floor before
# declining — weak-but-real material beats "I don't know".
RETRIEVAL_ENABLE_FALLBACK_RETRY=true
RETRIEVAL_FALLBACK_MIN_SCORE=0.18

# ===========================================================================
# Vector database
# ===========================================================================
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=mindstec_rag
QDRANT_VECTOR_DIMENSION=384      # must match the embedding model's output
QDRANT_DISTANCE_METRIC=Cosine
VECTOR_DB_TIMEOUT_SECONDS=10

# DANGER. When the live collection's dimension disagrees with config, the
# service refuses to serve rather than silently deleting the collection (which
# is what v1 did — total, unrecoverable loss of the knowledge base from a
# one-character typo). Set true ONLY for a deliberate, supervised re-index,
# and set it back to false immediately afterwards.
QDRANT_ALLOW_DESTRUCTIVE_RECREATE=false

# ===========================================================================
# API surface & safety
# ===========================================================================
CHAT_MESSAGE_MAX_LENGTH=4000
ENABLE_STREAMING=true

# Per-conversation, per-worker. With N workers the effective global limit is
# N x RATE_LIMIT_REQUESTS; a precise global limit belongs at the gateway.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

ENABLE_PROMPT_INJECTION_GUARD=true
ENABLE_OUTPUT_GUARD=true

# ===========================================================================
# Session store (Redis)
# ===========================================================================
# REDIS_URL defaults to CELERY_BROKER_URL, so existing single-Redis
# deployments keep working with no change. Redis is optional: without it the
# service falls back to bounded per-worker memory, which means conversation
# history is not shared across workers.
REDIS_URL=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_RECONNECT_BACKOFF_SECONDS=15

# ===========================================================================
# Prompt & knowledge assets
# ===========================================================================
PROMPTS_FILE=config/prompts.yaml
FAQ_FILE=config/faq.yaml
