# Server configuration
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=info
ENVIRONMENT=development
# Concurrent Gunicorn workers (see Dockerfile) — raise for real production load.
WEB_CONCURRENCY=2

# Internal service auth — required. Requests without this exact bearer token
# are rejected; there is no fallback default (see app/core/security.py).
AI_SERVICE_API_KEY=

# CORS — comma-separated list of allowed origins. Leave empty to disable CORS
# entirely (safe default for a backend-only microservice reached only via
# Django, not directly from a browser).
BACKEND_CORS_ORIGINS=

# LLM Configuration
# LLM_PROVIDER selects the primary provider; the other two are still used as
# an automatic fallback chain if the primary has no key configured or fails.
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional: comma-separated lists for load-spreading across multiple keys per
# provider (each single *_API_KEY above is automatically included).
OPENAI_API_KEYS=
GEMINI_API_KEYS=
GROQ_API_KEYS=
API_KEY_COOLDOWN_SECONDS=60
LLM_REQUEST_TIMEOUT_SECONDS=20
LLM_MAX_OUTPUT_TOKENS=700

# Query rewriting / classifier
ENABLE_QUERY_REWRITING=true
CLASSIFIER_MAX_RETRIES=2
HISTORY_WINDOW_MESSAGES=6
CHAT_MESSAGE_MAX_LENGTH=4000

# Embedding Configuration
# EMBEDDING_PROVIDER: huggingface, sentence_transformer, or openai
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_API_KEY=
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_TOKENS=512
EMBEDDING_CACHE_MAX_SIZE=256
EMBEDDING_CACHE_TTL_SECONDS=300

# Document chunking (approximate tokens, not characters — see ingest.py)
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Retrieval / re-ranking
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.30
RETRIEVAL_CONFIDENT_SCORE=0.55
RETRIEVAL_OVERFETCH_MULTIPLIER=3.0
RETRIEVAL_MAX_CONTEXT_CHUNKS=6
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=2
RETRIEVAL_DEDUP_SIMILARITY_THRESHOLD=0.90
RETRIEVAL_MAX_CONTEXT_TOKENS=3000
RETRIEVAL_ENABLE_RERANK=true
RERANK_LEXICAL_WEIGHT=0.3

# Vector DB (Qdrant) Configuration
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=mindstec_rag
QDRANT_VECTOR_DIMENSION=384
QDRANT_DISTANCE_METRIC=Cosine
VECTOR_DB_TIMEOUT_SECONDS=10

# Celery/Redis — used here only as the backing store for chat history
# (see app/api/v1/chat.py); falls back to in-memory (per-process, not
# persistent) if unreachable.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
